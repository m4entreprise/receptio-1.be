# =============================================================================
# RECEPTIO - Configuration Environment
# =============================================================================
# Copy this file to .env and fill in your actual values
# =============================================================================


# =============================================================================
# INFRASTRUCTURE
# =============================================================================

# --- Database ---------------------------------------------------------------
# PostgreSQL connection string (used by backend)
DATABASE_URL=postgresql://receptio:receptio123@localhost:5433/receptio

# --- Cache ------------------------------------------------------------------
# Redis instance for sessions, queues, and real-time features
REDIS_URL=redis://localhost:6379


# =============================================================================
# APPLICATION
# =============================================================================

# --- Backend Server ---------------------------------------------------------
PORT=3000
NODE_ENV=development          # development | production

# --- URLs -------------------------------------------------------------------
# Frontend API endpoint (used by Vite frontend)
VITE_API_URL=http://localhost:3000

# Backend CORS origin and redirect base URL
FRONTEND_URL=http://localhost:5173

# Public webhook base URL (Twilio, etc.)
PUBLIC_WEBHOOK_URL=http://localhost:3000

# --- Security ---------------------------------------------------------------
# JWT signing key - generate a strong random string for production
# Example: openssl rand -base64 64
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d


# =============================================================================
# AI PROVIDERS
# =============================================================================

# --- OpenAI -----------------------------------------------------------------
# Required for: voice transcription (STT), text-to-speech (TTS), chat completions
OPENAI_API_KEY=

# Speech-to-Text model
OPENAI_STT_MODEL=gpt-4o-mini-transcribe

# Text-to-Speech model and voice (options: alloy, echo, fable, onyx, nova, shimmer, ash)
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=ash

# Chat/Completion model for AI responses
OPENAI_LLM_MODEL=gpt-4o-mini

# --- Mistral ----------------------------------------------------------------
# Required for: alternative TTS and chat completions
MISTRAL_API_KEY=

# TTS retry configuration
MISTRAL_TTS_TIMEOUT_MS=30000
MISTRAL_TTS_MAX_RETRIES=3


# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# --- Twilio (Voice & SMS) ----------------------------------------------------
# Required for: inbound/outbound calls, voicemail, SMS notifications
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=                # E.164 format: +32412345678

# --- Resend (Email) ---------------------------------------------------------
# Required for: transactional emails, notifications, digests
RESEND_API_KEY=
FROM_EMAIL=noreply@receptio.be


# =============================================================================
# STORAGE
# =============================================================================

# Uploads directory (avatars, attachments)
UPLOAD_DIR=./uploads

# Call recordings directory
RECORDINGS_DIR=./recordings
