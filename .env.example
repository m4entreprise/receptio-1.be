# Database
DATABASE_URL=postgresql://receptio:receptio123@localhost:5433/receptio
POSTGRES_USER=receptio
POSTGRES_PASSWORD=receptio123
POSTGRES_DB=receptio

# Redis
REDIS_URL=redis://localhost:6379

# JWT
JWT_SECRET=your-super-secret-jwt-key-change-in-production
JWT_EXPIRES_IN=7d

# Backend
PORT=3000
NODE_ENV=development

# Frontend
VITE_API_URL=http://localhost:3000
FRONTEND_URL=http://localhost:5173
PUBLIC_WEBHOOK_URL=http://localhost:3000

# OpenAI
OPENAI_API_KEY=
OPENAI_STT_MODEL=gpt-4o-mini-transcribe
OPENAI_TTS_MODEL=gpt-4o-mini-tts
OPENAI_TTS_VOICE=ash
OPENAI_LLM_MODEL=gpt-5.4-nano

# Twilio
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Resend (emails - à configurer)
RESEND_API_KEY=
FROM_EMAIL=noreply@receptio.be

# Storage
UPLOAD_DIR=./uploads
RECORDINGS_DIR=./recordings
